# Environment Configuration for Optima

# Port to run the server on (default: 5000)
PORT=5000

# Environment mode ('production' or 'development')
NODE_ENV=production

# MongoDB Connection URI 
# Required in production. In development, if omitted, Optima uses an in-memory database.
MONGODB_URI=mongodb://localhost:27017/optima

# Optional: CORS Origin settings (default: * in development)
CORS_ORIGIN=*
